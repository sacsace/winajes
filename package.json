{
  "name": "winajes",
  "version": "1.0.0",
  "private": true,
  "description": "WINAJES Constructions India Pvt. Ltd. Corporate Website",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:all": "run-p dev:web dev:api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "start:web": "npm run start --workspace=apps/web",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate": "node scripts/init-db.mjs --migrate-only",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
